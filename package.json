{
  "name": "sf-pi",
  "version": "0.101.1",
  "private": true,
  "type": "module",
  "description": "Opinionated Salesforce developer extensions for the pi coding agent — Apex/LWC LSP, Agent Script authoring, Slack research, and a TUI manager.",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "salesforce",
    "salesforce-dev",
    "developer-tools"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Salesforce, Inc.",
    "url": "https://github.com/salesforce"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salesforce/sf-pi.git"
  },
  "bugs": {
    "url": "https://github.com/salesforce/sf-pi/issues"
  },
  "homepage": "https://github.com/salesforce/sf-pi#readme",
  "engines": {
    "node": ">=22.19"
  },
  "pi": {
    "extensions": [
      "./extensions/sf-welcome/index.ts",
      "./extensions/sf-devbar/index.ts",
      "./extensions/sf-ohana-spinner/index.ts",
      "./extensions/sf-pi-manager/index.ts",
      "./extensions/sf-llm-gateway-internal/index.ts",
      "./extensions/sf-guardrail/index.ts",
      "./extensions/sf-brain/index.ts",
      "./extensions/sf-slack/index.ts",
      "./extensions/sf-data360/index.ts",
      "./extensions/sf-lsp/index.ts",
      "./extensions/sf-agentscript/index.ts",
      "./extensions/sf-skills/index.ts",
      "./extensions/sf-feedback/index.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "scripts": {
    "generate-catalog": "node scripts/generate-catalog.mjs",
    "generate-catalog:check": "node scripts/generate-catalog.mjs --check",
    "generate-d360-registry": "node scripts/generate-d360-registry.mjs",
    "generate-d360-registry:check": "node scripts/generate-d360-registry.mjs --check",
    "docs:health": "node scripts/docs-health.mjs",
    "docs:health:check": "node scripts/docs-health.mjs --check",
    "docs:changed": "node scripts/docs-changed.mjs",
    "spdx": "node scripts/add-spdx-headers.mjs",
    "spdx:check": "node scripts/add-spdx-headers.mjs --check",
    "check": "tsc --noEmit -p tsconfig.json",
    "check:panels": "node scripts/check-panel-consistency.mjs",
    "check:boot-path": "node scripts/check-boot-path.mjs",
    "eslint": "eslint . --max-warnings=0",
    "eslint:fix": "eslint . --fix",
    "lint": "npm run format:check && npm run generate-d360-registry:check && npm run generate-catalog:check && npm run docs:health:check && npm run spdx:check && npm run eslint",
    "validate:ci": "npm run validate && npm run eslint && npm run docs:health:check && bash scripts/check-llm-artifacts.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:sf-llm-gateway-internal:codex": "vitest run extensions/sf-llm-gateway-internal/tests/codex-regression.test.ts",
    "validate": "./scripts/validate.sh",
    "scaffold": "node scripts/scaffold.mjs",
    "preinstall": "node scripts/check-node-version.mjs",
    "prepare": "node scripts/prepare.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.75.0",
    "typebox": "*"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@earendil-works/pi-ai": "^0.75.0",
    "@earendil-works/pi-coding-agent": "^0.75.0",
    "@earendil-works/pi-tui": "^0.75.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.6.2",
    "typebox": "^1.1.37",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@salesforce/core": "^8.29.1",
    "@salesforce/source-deploy-retrieve": "^12.35.8",
    "node-emoji": "^2.2.0",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "overridesNotes": {
    "fast-xml-parser": "Force >= 5.7.0 to clear GHSA-gh4j-gqv2-49f6 (XMLBuilder CDATA injection). Reaches sf-pi through pi-ai -> AWS SDK Bedrock client; remove once upstream AWS SDK resolves the advisory.",
    "@mistralai/mistralai": "Hard-pin to 2.2.1, the last clean release before the npm-publish-account takeover (GHSA-3q49-cfcf-g5fm, published 2026-05-11). Versions 2.2.2/2.2.3/2.2.4 are flagged as malware by GitHub Advisory DB. Reaches sf-pi transitively through @earendil-works/pi-ai. Tarball verified: SRI integrity sha512-uKU8C... matches registry, hasInstallScript=false, no preinstall/postinstall hooks. Remove once upstream republishes a clean Mistral SDK and pi-ai bumps past it."
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0",
    "@mistralai/mistralai": "2.2.1"
  }
}
