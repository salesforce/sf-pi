{
  "d360_segment_create": {
    "displayName": "High Value Customers",
    "segmentOnApiName": "UnifiedIndividual__dlm",
    "segmentType": "Ui",
    "segmentCreationFlow": "Datakit",
    "publishSchedule": "TwentyFour",
    "publishScheduleStartDateTime": "2026-03-28T00:00:00.000Z",
    "publishScheduleEndDate": "2027-03-28T00:00:00.000Z",
    "includeDbt": {
      "models": {
        "models": [
          {
            "sql": "SELECT DISTINCT\n  individual.ssot__Id__c as individual_id\nFROM UnifiedIndividual__dlm as individual\nWHERE individual.AnnualRevenue__c > 100000\n  AND individual.Industry__c IN ('Technology', 'Finance')\nORDER BY individual.AnnualRevenue__c DESC\n",
            "name": "high_value_segment"
          }
        ]
      }
    },
    "description": "Customers with annual revenue > $100k in Technology or Finance"
  },
  "d360_ci_create": {
    "apiName": "Revenue_By_Region__cio",
    "displayName": "Revenue By Region",
    "definitionType": "CALCULATED_METRIC",
    "publishScheduleInterval": "SYSTEM_MANAGED",
    "expression": "SELECT\n  Account__dlm.Region__c as region,\n  SUM(Opportunity__dlm.Amount__c) as total_revenue,\n  COUNT(DISTINCT Opportunity__dlm.ssot__Id__c) as opp_count,\n  AVG(Opportunity__dlm.Amount__c) as avg_opportunity_size\nFROM Account__dlm\nINNER JOIN Opportunity__dlm\n  ON Account__dlm.ssot__Id__c = Opportunity__dlm.AccountId__c\nWHERE Opportunity__dlm.CloseDate__c >= CURRENT_DATE - INTERVAL 365 DAY\nGROUP BY Account__dlm.Region__c\nORDER BY total_revenue DESC\n"
  },
