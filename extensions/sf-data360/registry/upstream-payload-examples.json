  "d360_sdm_relationship_create": {
    "label": "Account to Opportunity",
    "leftSemanticDefinitionApiName": "Account",
    "rightSemanticDefinitionApiName": "Opportunity",
    "criteria": [
      {
        "joinOperator": "Equals",
        "leftFieldType": "TableField",
        "leftSemanticFieldApiName": "Account_Id",
