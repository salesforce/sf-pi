    ],
    "cardinality": "OneToMany",
    "joinType": "Auto"
  },
  "d360_sdm_calc_dim_create": {
    "label": "Revenue Tier",
    "dataType": "Text",
    "expression": "IF [Account].[AnnualRevenue] > 1000000 THEN 'Enterprise' ELSEIF [Account].[AnnualRevenue] > 100000 THEN 'Mid-Market' ELSE 'SMB' END"
  },
  "d360_sdm_calc_measure_create": {
    "label": "Total Pipeline",
    "dataType": "Number",
    "aggregationType": "UserAgg",
    "expression": "SUM([Opportunity].[Amount])"
  },
  "d360_sdm_query": {
    "semanticModelId": "0163L000000TMKDQA4",
    "structuredSemanticQuery": {
      "options": {
        "limitOptions": {
          "limit": 100
        }
      },
      "fields": [
        {
          "rowGrouping": true,
          "expression": {
            "tableField": {
              "name": "Region",
              "tableName": "Account"
            }
          },
          "alias": "Region"
        },
        {
          "semanticAggregationMethod": "SEMANTIC_AGGREGATION_METHOD_SUM",
          "expression": {
            "tableField": {
              "name": "AnnualRevenue",
              "tableName": "Account"
            }
          },
          "alias": "TotalRevenue"
        },
        {
          "rowGrouping": true,
          "expression": {
            "semanticField": {
              "name": "Revenue_Tier"
            }
          },
          "alias": "RevenueSegment"
        }
      ]
    }
  },
  "d360_ir_create": {
    "matchRules": [
      {
        "criteria": [
          {
            "shouldMatchOnBlank": false,
            "fieldName": "ssot__EmailAddress__c",
            "entityName": "ssot__ContactPointEmail__dlm",
            "matchMethodType": "exactnormalized"
          }
        ],
        "label": "Normalized Email"
      },
      {
        "criteria": [
          {
            "shouldMatchOnBlank": false,
            "fieldName": "ssot__FirstName__c",
            "entityName": "ssot__Individual__dlm",
            "matchMethodType": "fuzzy"
          },
          {
            "shouldMatchOnBlank": false,
            "fieldName": "ssot__LastName__c",
            "entityName": "ssot__Individual__dlm",
            "matchMethodType": "exact"
          },
          {
            "shouldMatchOnBlank": false,
            "fieldName": "ssot__EmailAddress__c",
            "entityName": "ssot__ContactPointEmail__dlm",
            "matchMethodType": "exactnormalized"
          }
        ],
        "label": "Fuzzy Name and Normalized Email"
      }
    ],
    "reconciliationRules": [
      {
        "fields": [
          {
            "fieldName": "ssot__Id__c",
            "ruleType": "sourcesequence",
            "sources": [
              {
                "name": "Contact_Home__dll"
              },
              {
                "name": "CustomerStream__dll"
              }
            ],
            "shouldIgnoreEmptyValue": true
          }
        ],
        "entityName": "ssot__Individual__dlm",
        "ruleType": "sourcesequence",
        "sources": [
          {
            "name": "Contact_Home__dll"
          },
          {
            "name": "CustomerStream__dll"
          }
        ],
        "shouldIgnoreEmptyValue": true
      },
      {
        "entityName": "ssot__ContactPointEmail__dlm",
        "ruleType": "sourcesequence",
        "sources": [
          {
            "name": "Contact_Home__dll"
          },
          {
            "name": "CustomerStream__dll"
          }
        ],
        "shouldIgnoreEmptyValue": true
      }
    ],
    "description": "Match individuals by normalized email, then fuzzy name + email",
    "configurationType": "individual",
    "rulesetId": "sufx",
    "doesRunAutomatically": false,
    "_note": "configurationType REQUIRED: 'individual' or 'account'. matchMethodType values: exact, exactnormalized, fuzzy, fuzzyhigh, fuzzylow. reconciliationRules ruleType values: lastupdated (requires LastModifiedDate mapped), mostfrequent, sourcesequence. IMPORTANT: every reconciliationRule MUST include ruleType \u2014 omitting it causes a server 500. For lastupdated, the DMO must have ssot__LastModifiedDate__c mapped; use sourcesequence if not.",
    "label": "Email and Name Matching"
  },
  "d360_transform_create": {
    "name": "Account Enrichment",
    "description": "Enrich account data with aggregated pipeline and customer counts",
    "targetDmo": "Account__dlm",
    "sql": "SELECT\n  Account__dlm.ssot__Id__c,\n  Account__dlm.Name__c,\n  Account__dlm.Industry__c,\n  SUM(Opportunity__dlm.Amount__c) as total_pipeline,\n  COUNT(DISTINCT Opportunity__dlm.ssot__Id__c) as open_opportunities,\n  COUNT(DISTINCT Contact__dlm.ssot__Id__c) as contact_count,\n  MAX(Activity__dlm.LastActivityDate__c) as last_activity_date\nFROM Account__dlm\nLEFT JOIN Opportunity__dlm\n  ON Account__dlm.ssot__Id__c = Opportunity__dlm.AccountId__c\n  AND Opportunity__dlm.IsClosed__c = false\nLEFT JOIN Contact__dlm\n  ON Account__dlm.ssot__Id__c = Contact__dlm.AccountId__c\nLEFT JOIN Activity__dlm\n  ON Account__dlm.ssot__Id__c = Activity__dlm.AccountId__c\nGROUP BY\n  Account__dlm.ssot__Id__c,\n  Account__dlm.Name__c,\n  Account__dlm.Industry__c\n"
  },
