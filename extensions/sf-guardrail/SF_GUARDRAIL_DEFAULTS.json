{
  "version": 1,
  "productionAliases": [],
  "headlessEscapeHatchEnv": "SF_GUARDRAIL_ALLOW_HEADLESS",
  "confirmTimeoutMs": 120000,
  "policies": {
    "rules": [
      {
        "id": "sf-destructive-changes-xml",
        "description": "Destructive-deploy manifest — block direct edits",
        "patterns": [
          {
            "pattern": "**/destructiveChanges*.xml"
          }
        ],
        "protection": "noAccess",
        "blockMessage": "Writes to {file} are blocked by sf-guardrail. Stage deletes via a reviewed metadata change, not by hand-editing destructiveChanges.xml.",
        "enabled": true,
        "onlyIfExists": false
      },
      {
        "id": "sf-forceignore",
        "description": ".forceignore — changes ship/retrieve behavior silently",
        "patterns": [
          {
            "pattern": "**/.forceignore"
          }
        ],
        "protection": "readOnly",
        "blockMessage": "{file} is read-only under sf-guardrail. Edits alter retrieve/deploy behavior — change it from a terminal with review.",
        "enabled": true,
        "onlyIfExists": false
      },
      {
        "id": "sf-cli-state",
        "description": "SF CLI / sfdx state directories — never edit by hand",
        "patterns": [
          {
            "pattern": ".sf/**"
          },
          {
            "pattern": ".sfdx/**"
          }
        ],
        "allowedPatterns": [
          {
            "pattern": ".sfdx/agents/**"
          }
        ],
        "protection": "noAccess",
        "blockMessage": "{file} is internal sf CLI state. sf-guardrail blocks direct access; use sf commands instead. (Carve-out: .sfdx/agents/** is allowed for sf-agentscript preview sessions — the Salesforce-standard agent session layout.)",
        "enabled": true,
        "onlyIfExists": false
      },
      {
        "id": "secret-files",
        "description": "Dotenv-style secret files",
        "patterns": [
          {
            "pattern": ".env"
          },
          {
            "pattern": ".env.local"
          },
          {
            "pattern": ".env.production"
          },
          {
            "pattern": ".env.prod"
          },
          {
            "pattern": ".dev.vars"
          }
        ],
        "allowedPatterns": [
          {
            "pattern": ".env.example"
          },
          {
            "pattern": ".env.sample"
          },
          {
            "pattern": ".env.test"
          },
          {
            "pattern": "*.example.env"
          },
          {
            "pattern": "*.sample.env"
          },
          {
            "pattern": "*.test.env"
          }
        ],
        "protection": "noAccess",
        "blockMessage": "{file} may contain secrets; sf-guardrail blocks access. Use an *.example.env template or an environment-backed secret store.",
        "enabled": true,
        "onlyIfExists": true
      }
    ]
  },
  "commandGate": {
    "patterns": [
      {
        "id": "find-delete",
        "pattern": "find -delete",
        "description": "find deleting matched files"
      },
      {
        "id": "find-exec-rm",
        "pattern": "find -exec rm",
        "description": "find executing rm on matched files"
      },
      {
        "id": "rm-rf",
        "pattern": "rm -rf",
        "description": "recursive force delete"
      },
      {
        "id": "rm-fr",
        "pattern": "rm -fr",
        "description": "recursive force delete (flag order variant)"
      },
      {
        "id": "rm-r-f",
        "pattern": "rm -r -f",
        "description": "recursive force delete (split flags)"
      },
      {
        "id": "shred",
        "pattern": "shred",
        "description": "secure file shredding"
      },
      {
        "id": "srm",
        "pattern": "srm",
        "description": "secure recursive file removal"
      },
      {
        "id": "wipe",
        "pattern": "wipe",
        "description": "secure file wiping"
      },
      {
        "id": "truncate-zero",
        "pattern": "truncate -s 0",
        "description": "truncate file contents to zero bytes"
      },
      {
        "id": "sudo",
        "pattern": "sudo",
        "description": "superuser command"
      },
      {
        "id": "chmod-777",
        "pattern": "chmod -R 777",
        "description": "recursive world-writable chmod"
      },
      {
        "id": "chmod-000",
        "pattern": "chmod -R 000",
        "description": "recursive permission lockout chmod"
      },
      {
        "id": "chmod-a-rwx",
        "pattern": "chmod -R a+rwx",
        "description": "recursive world-writable chmod"
      },
      {
        "id": "chmod-ugo-rwx",
        "pattern": "chmod -R ugo+rwx",
        "description": "recursive world-writable chmod"
      },
      {
        "id": "chown-recursive",
        "pattern": "chown -R",
        "description": "recursive ownership change"
      },
      {
        "id": "chgrp-recursive",
        "pattern": "chgrp -R",
        "description": "recursive group ownership change"
      },
      {
        "id": "dd-of",
        "pattern": "dd of=",
        "description": "dd writing to an output device/file"
      },
      {
        "id": "mkfs",
        "pattern": "mkfs.*",
        "description": "filesystem formatting command"
      },
      {
        "id": "remote-script-to-shell",
        "pattern": "remote-script-to-shell",
        "description": "pipe remote script into a shell"
      },
      {
        "id": "base64-decode-to-shell",
        "pattern": "base64-decode-to-shell",
        "description": "pipe decoded base64 payload into a shell"
      },
      {
        "id": "killall-9",
        "pattern": "killall -9",
        "description": "force kill matching processes"
      },
      {
        "id": "pkill-9",
        "pattern": "pkill -9",
        "description": "force kill matching processes"
      },
      {
        "id": "reboot",
        "pattern": "reboot",
        "description": "reboot the machine"
      },
      {
        "id": "shutdown",
        "pattern": "shutdown",
        "description": "shut down the machine"
      },
      {
        "id": "git-reset-hard",
        "pattern": "git reset --hard",
        "description": "discard local git changes"
      },
      {
        "id": "git-clean-fd",
        "pattern": "git clean -fd",
        "description": "delete untracked files and directories"
      },
      {
        "id": "git-clean-fdx",
        "pattern": "git clean -fdx",
        "description": "delete all untracked and ignored files"
      },
      {
        "id": "git-force-push",
        "pattern": "git push --force",
        "description": "git force push"
      },
      {
        "id": "git-force-push-short",
        "pattern": "git push -f",
        "description": "git force push (short flag)"
      },
      {
        "id": "docker-system-prune",
        "pattern": "docker system prune",
        "description": "delete Docker images, containers, networks, or cache"
      },
      {
        "id": "docker-compose-down-volumes",
        "pattern": "docker compose down -v",
        "description": "stop compose stack and delete volumes"
      },
      {
        "id": "docker-rm-force",
        "pattern": "docker rm -f",
        "description": "force remove Docker containers"
      },
      {
        "id": "kubectl-delete",
        "pattern": "kubectl delete",
        "description": "delete Kubernetes resources"
      },
      {
        "id": "terraform-destroy",
        "pattern": "terraform destroy",
        "description": "destroy Terraform-managed infrastructure"
      },
      {
        "id": "terraform-apply-destroy",
        "pattern": "terraform apply -destroy",
        "description": "destroy Terraform-managed infrastructure"
      },
      {
        "id": "dropdb",
        "pattern": "dropdb",
        "description": "drop PostgreSQL database"
      },
      {
        "id": "redis-flushall",
        "pattern": "redis-cli FLUSHALL",
        "description": "delete all Redis keys"
      },
      {
        "id": "redis-flushdb",
        "pattern": "redis-cli FLUSHDB",
        "description": "delete Redis database keys"
      },
      {
        "id": "sf-project-delete-source",
        "pattern": "sf project delete source",
        "description": "delete source locally and from an org"
      },
      {
        "id": "sf-project-delete-tracking",
        "pattern": "sf project delete tracking",
        "description": "delete local source tracking information"
      },
      {
        "id": "sf-project-reset-tracking",
        "pattern": "sf project reset tracking",
        "description": "reset local and remote source tracking"
      },
      {
        "id": "sf-package-delete",
        "pattern": "sf package delete",
        "description": "delete a package"
      },
      {
        "id": "sf-package-version-delete",
        "pattern": "sf package version delete",
        "description": "delete a package version"
      },
      {
        "id": "sf-package-uninstall",
        "pattern": "sf package uninstall",
        "description": "uninstall a package from an org"
      },
      {
        "id": "sf-package-version-promote",
        "pattern": "sf package version promote",
        "description": "promote a package version to released"
      },
      {
        "id": "sf-package-push-upgrade-schedule",
        "pattern": "sf package push-upgrade schedule",
        "description": "schedule a package push upgrade"
      },
      {
        "id": "sf-package-push-upgrade-abort",
        "pattern": "sf package push-upgrade abort",
        "description": "abort a package push upgrade"
      },
      {
        "id": "sf-org-logout-all",
        "pattern": "sf org logout --all",
        "description": "log out of every authenticated Salesforce org"
      },
      {
        "id": "sf-org-generate-password",
        "pattern": "sf org generate password",
        "description": "generate or expose a Salesforce org user password"
      },
      {
        "id": "sf-plugins-install",
        "pattern": "sf plugins install",
        "description": "install a Salesforce CLI plugin"
      },
      {
        "id": "sf-plugins-uninstall",
        "pattern": "sf plugins uninstall",
        "description": "uninstall a Salesforce CLI plugin"
      },
      {
        "id": "sf-plugins-remove",
        "pattern": "sf plugins remove",
        "description": "remove a Salesforce CLI plugin"
      },
      {
        "id": "sf-plugins-reset",
        "pattern": "sf plugins reset",
        "description": "reset Salesforce CLI plugin state"
      },
      {
        "id": "sf-agent-adl-delete",
        "pattern": "sf agent adl delete",
        "description": "delete an Agentforce Data Library"
      },
      {
        "id": "sf-agent-adl-file-delete",
        "pattern": "sf agent adl file delete",
        "description": "delete a file from an Agentforce Data Library"
      },
      {
        "id": "sf-org-delete",
        "pattern": "sf org delete",
        "description": "delete scratch/sandbox org"
      },
      {
        "id": "sf-org-auth-show-access-token",
        "pattern": "org auth show-access-token",
        "description": "reveal Salesforce org access token"
      },
      {
        "id": "sf-org-auth-show-sfdx-auth-url",
        "pattern": "org auth show-sfdx-auth-url",
        "description": "reveal Salesforce org SFDX auth URL"
      },
      {
        "id": "sf-org-auth-show-user-password",
        "pattern": "org auth show-user-password",
        "description": "reveal Salesforce org user password"
      },
      {
        "id": "sf-temp-show-secrets",
        "pattern": "SF_TEMP_SHOW_SECRETS=true",
        "description": "temporarily restore legacy Salesforce CLI secret output"
      }
    ],
    "allowedPatterns": [],
    "autoDenyPatterns": []
  },
  "orgAwareGate": {
    "rules": [
      {
        "id": "sf-deploy-prod",
        "description": "Metadata deploy targeting production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["project", "deploy", ["start", "resume", "quick"]]
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Deploy to PRODUCTION org {orgAlias} ({orgType})?\n\n  {command}\n\nPrefer `sf project deploy validate` as a rehearsal first.",
        "enabled": true
      },
      {
        "id": "sf-apex-run-prod",
        "description": "Anonymous Apex targeting production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["apex", "run"]
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Run anonymous Apex on PRODUCTION org {orgAlias}?\n\n  {command}\n\nWrap DML in Savepoint + Database.rollback() when rehearsing.",
        "enabled": true
      },
      {
        "id": "sf-data-mutate-prod",
        "description": "sf data delete/update/upsert/import targeting production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["data", ["delete", "update", "upsert", "import"]]
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Mutate data on PRODUCTION org {orgAlias}?\n\n  {command}",
        "enabled": true
      },
      {
        "id": "sf-org-api-destructive-prod",
        "description": "sf org api with destructive HTTP method on production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["org", "api"],
            "flagIn": {
              "--method": ["DELETE", "PATCH", "PUT"]
            }
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Call PRODUCTION org {orgAlias} REST API with destructive HTTP method?\n\n  {command}",
        "enabled": true
      },
      {
        "id": "sf-data-create-prod",
        "description": "sf data create record/file targeting production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["data", "create", ["record", "file"]]
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Create data on PRODUCTION org {orgAlias}?\n\n  {command}"
      },
      {
        "id": "sf-package-install-prod",
        "description": "Package install or upgrade targeting production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["package", "install"]
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Install or upgrade a package on PRODUCTION org {orgAlias}?\n\n  {command}"
      },
      {
        "id": "sf-agent-activate-prod",
        "description": "Agent activation/deactivation targeting production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["agent", ["activate", "deactivate"]]
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Change active agent state on PRODUCTION org {orgAlias}?\n\n  {command}"
      },
      {
        "id": "sf-agent-publish-prod",
        "description": "Agent authoring-bundle publish targeting production",
        "match": {
          "tool": "bash",
          "ast": {
            "cmd": "sf",
            "subCmd": ["agent", "publish", "authoring-bundle"]
          }
        },
        "whenOrgType": ["production"],
        "action": "confirm",
        "confirmMessage": "Publish an agent authoring bundle to PRODUCTION org {orgAlias}?\n\n  {command}"
      }
    ]
  }
}
