; SPDX-License-Identifier: Apache-2.0
; Always run `npm audit` on install. Fail fast on high-severity issues.
audit=true
audit-level=high

; Avoid pinning to exact versions — Dependabot keeps them fresh.
save-exact=false

; Reduce install noise in CI logs.
fund=false

; Pi's peerDependencies use `*` wildcards that npm's strict peers resolver
; doesn't like. Fall back to npm 6 resolver behavior for this repo.
legacy-peer-deps=true
